# Copy this to .env and fill in the values

# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas (optional - app works with local JSON fallback if not set)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/nutricare?retryWrites=true&w=majority

# Gemini AI (optional - for AI chatbot responses)
GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=95367770102-8kn2qu6rjp2e1lsbapkevdvv9jggomg7.apps.googleusercontent.com

# JWT Secret (change this to a long random string in production!)
JWT_SECRET=change_this_to_a_very_long_random_secret_string_in_production


# Frontend URL (your Vercel frontend URL - used for CORS)
CLIENT_URL=https://your-app.vercel.app
